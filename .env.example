# ============================================================================
# LifeHub — Variables de entorno
# ============================================================================
# Copia este archivo a `.env` y llena los valores reales.
# `.env` está en .gitignore y NO debe commitearse.
# ============================================================================

# --- PostgreSQL ---
# El docker-compose.yml ya usa estos valores; cámbialos si modificas el compose.
DATABASE_URL=postgresql://lifehub:lifehub_dev_password@localhost:5432/lifehub_dev

# --- Notion ---
# 1. Crear integración interna en https://www.notion.so/profile/integrations
# 2. Copiar el token aquí (empieza con "secret_..." o "ntn_...")
# 3. En Notion: abrir página "Life Hub 2.0" → Connections → agregar la integración
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# IDs de las bases de datos en Notion (sin guiones)
# El de transactions ya está pre-rellenado con tu DB real.
NOTION_DB_TRANSACTIONS=32adeebec9b180029cbbf7cfc614bbec
NOTION_DB_ACCOUNTS=32adeebec9b180f8a653e89f50252f85
NOTION_DB_TRANSACTION_ITEMS=32bdeebec9b180b09085ee6893df4972

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Web ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- User (single-user mode hardcoded en Fase 1) ---
OWNER_USER_ID=00000000-0000-0000-0000-000000000001
